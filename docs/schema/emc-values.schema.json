{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tufkan1/ProjectEX/main/docs/schema/emc-values.schema.json",
  "title": "ProjectEX EMC values",
  "description": "One versioned ProjectEX EMC data-pack resource.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "values"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "priority": {
      "type": "integer",
      "minimum": -10000,
      "maximum": 10000,
      "default": 0
    },
    "values": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/definition"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+:[a-z0-9/._-]+$"
    },
    "definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item"],
      "properties": {
        "item": {
          "$ref": "#/$defs/identifier"
        },
        "components": {
          "type": "object",
          "description": "Optional exact item-component constraints. Object key order is ignored."
        },
        "emc": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]{0,999})$",
          "description": "Canonical non-negative integer string; strings preserve arbitrary precision."
        },
        "alias": {
          "$ref": "#/$defs/identifier"
        },
        "remove": {
          "const": true
        }
      },
      "oneOf": [
        {
          "required": ["emc"],
          "not": {
            "anyOf": [
              { "required": ["alias"] },
              { "required": ["remove"] }
            ]
          }
        },
        {
          "required": ["alias"],
          "not": {
            "anyOf": [
              { "required": ["emc"] },
              { "required": ["remove"] }
            ]
          }
        },
        {
          "required": ["remove"],
          "not": {
            "anyOf": [
              { "required": ["emc"] },
              { "required": ["alias"] }
            ]
          }
        }
      ]
    }
  }
}
